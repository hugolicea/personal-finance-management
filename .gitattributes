# Ensure shell scripts always use LF line endings
*.sh text eol=lf

# Ensure Python files use LF
*.py text eol=lf

# Ensure config files use LF
*.ini text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
Dockerfile text eol=lf

# Windows-specific files can use CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf
